# Shopping Cart System

cart = []                     # List for cart items
categories = set()            # Set for unique categories
prices = {}                   # Dictionary for item-price pairs

while True:
    print("\n===== Shopping Cart Menu =====")
    print("1. Add Item")
    print("2. Remove Item")
    print("3. View Cart")
    print("4. View Total Bill")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        item = input("Enter item name: ").title()

        if item in prices:
            print("Item already exists in cart!")
            continue

        try:
            price = float(input("Enter item price: "))
        except ValueError:
            print("Invalid price!")
            continue

        category = input("Enter item category: ").title()

        cart.append(item)
        prices[item] = price
        categories.add(category)

        print(f"{item} added successfully!")

    elif choice == "2":
        item = input("Enter item to remove: ").title()

        if item in cart:
            cart.remove(item)
            del prices[item]
            print(f"{item} removed successfully!")
        else:
            print("Item not found in cart.")

    elif choice == "3":
        if not cart:
            print("\nYour cart is empty.")
        else:
            print("\n===== Cart Items =====")
            for item in cart:
                print(f"{item} - ₹{prices[item]:.2f}")

            print("\nUnique Categories:")
            for cat in categories:
                print("-", cat)

    elif choice == "4":
        total = sum(prices.values())
        print(f"\nTotal Bill = ₹{total:.2f}")

    elif choice == "5":
        print("Thank you for shopping!")
        break

    else:
        print("Invalid choice! Please try again.")
